# Copy to .env and fill in your values. Never commit .env.

# Teltonika router (RUTX11 etc.). Leave ROUTER_PASSWORD blank to disable.
ROUTER_URL=http://192.168.1.1
ROUTER_USER=data
ROUTER_PASSWORD=

# Victron BLE devices. JSON array per device with:
#   mac, key, name  — required
#   hint            — optional type hint: "charger" or "dcdc"
#   persistent      — optional bool; if true the card stays visible (gray) when offline
# Get the encryption key from the Victron app:
#   Settings -> Product info -> "Show" next to Instant readout via Bluetooth.
# Leave empty / unset to disable the Victron source.
VICTRON_DEVICES=[{"mac":"aa:bb:cc:dd:ee:ff","key":"your32charencryptionkey","name":"SmartShunt"},{"mac":"f3:2f:c1:5d:e7:8c","key":"f35eca0daf1c1aa4f1e076010d53d9ab","name":"IP22","hint":"charger","persistent":true},{"mac":"bb:bb:bb:bb:bb:bb","key":"your32charencryptionkey","name":"Orion-Tr","hint":"dcdc","persistent":true}]

# Shelly H&T Gen3. Pushes to GET /api/ingest/shelly on each wake.
# Two separate actions on the device, one URL each:
#   Temperature action: http://<this-host>:8000/api/ingest/shelly?temperature=${ev.tC}
#   Humidity action:    http://<this-host>:8000/api/ingest/shelly?humidity=${ev.rh}
SHELLY_NAME=Indoor
SHELLY_SOURCE_ID=shelly.indoor

# Raspberry Pi host status (CPU temp, load, memory, uptime). Reads /sys and
# /proc; works out of the box with the privileged + host-network compose setup.
PI_NAME=Raspberry Pi
PI_SOURCE_ID=system.pi
