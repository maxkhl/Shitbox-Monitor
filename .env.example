# Copy to .env and fill in your values. Never commit .env.

# Teltonika router (RUTX11 etc.). Leave ROUTER_PASSWORD blank to disable.
ROUTER_URL=http://192.168.1.1
ROUTER_USER=data
ROUTER_PASSWORD=

# Victron BLE devices. JSON array of {mac, key, name} per device.
# Get the encryption key from the Victron app:
#   Settings -> Product info -> "Show" next to Instant readout via Bluetooth.
# Leave empty / unset to disable the Victron source.
VICTRON_DEVICES=[{"mac":"aa:bb:cc:dd:ee:ff","key":"your32charencryptionkey","name":"SmartShunt"}]
